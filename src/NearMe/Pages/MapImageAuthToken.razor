@page "/mapimageauthtoken"
@using System.Text
@using System.Globalization
@using NearMe.Services
@inject IGeolocationService GeolocationService

<div class="d-flex flex-wrap gap-2 align-items-center mb-3">
    <button class="btn btn-primary" @onclick="RequestLocationAsync" disabled="@isLoading">
        @(isLoading ? "Locating..." : "Try to locate my position")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(LocationMessage))
{
    <div class="alert alert-warning">@LocationMessage</div>
}

@if (isLoading)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(PngImage))
    {
        <div class="row">
            <div style="width: 300px; height: 300px;">
                <img src="@PngImage" height="300" width="300"/>
            </div>
        </div>
    }
}

@code {
    private const int MaxLocationRetries = 2;

    private static readonly PositionOptions LocationOptions = new()
    {
        EnableHighAccuracy = true,
        Timeout = 10000,
        MaximumAge = 0
    };

    string PngImage = string.Empty;
    string Latitude = "-15.793889";
    string Longitude = "-47.882778";
    bool isLoading = false;
    int locationRetryCount;
    string? LocationMessage;

    protected GeolocationPosition? CurrentPosition { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RequestLocationAsync();
        }
    }

    public async Task RequestLocationAsync()
    {
        if (isLoading)
        {
            return;
        }

        isLoading = true;
        LocationMessage = null;
        StateHasChanged();

        await GeolocationService.GetCurrentPositionAsync(
            this,
            nameof(OnPositionReceived),
            nameof(OnPositionError),
            LocationOptions);
    }

    [JSInvokable]
    public async Task OnPositionReceived(GeolocationPosition position)
    {
        CurrentPosition = position;
        LocationMessage = null;
        locationRetryCount = 0;

        string? currentLatitude = position.Coords?.Latitude.ToString("F2", CultureInfo.InvariantCulture);
        string? currentLongitude = position.Coords?.Longitude.ToString("F2", CultureInfo.InvariantCulture);

        if (currentLatitude != null && currentLongitude != null)
        {
            Latitude = Convert.ToDouble(currentLatitude, CultureInfo.InvariantCulture)
                .ToString(CultureInfo.InvariantCulture);
            Longitude = Convert.ToDouble(currentLongitude, CultureInfo.InvariantCulture)
                .ToString(CultureInfo.InvariantCulture);
        }

        await LoadTileAsync();
    }

    [JSInvokable]
    public async Task OnPositionError(GeolocationPositionError error)
    {
        if (locationRetryCount < MaxLocationRetries &&
            (error.Code == error.POSITION_UNAVAILABLE || error.Code == error.TIMEOUT))
        {
            locationRetryCount++;
            await Task.Delay(1000);
            isLoading = false;
            await RequestLocationAsync();
            return;
        }

        LocationMessage = error.Code == error.PERMISSION_DENIED
            ? "Location permission denied in browser. Please enable location access and try again."
            : "Could not obtain browser location. Displaying a default map.";

        await LoadTileAsync();
    }

    private async Task LoadTileAsync()
    {
        PngImage = await GetTile();
        isLoading = false;
        StateHasChanged();
    }

    public async Task<string> GetTile()
    {
        string pngImage = "";
        string accessToken = await AuthService.GetAccessToken();

        string clientId = AuthService.ClientId ?? string.Empty;

        using var client = new HttpClient();

        client.DefaultRequestHeaders.Accept.Clear();
        client.DefaultRequestHeaders.Add("x-ms-client-id", clientId);
        client.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);

        var sb = new StringBuilder();
        sb.Append("https://atlas.microsoft.com/map/static/png?");
        sb.Append("api-version=1.0&layer=basic&style=main&zoom=12&");
        sb.Append($"center={Longitude},{Latitude}&");
        sb.Append($"pins=default%7C%7C{Longitude}+{Latitude}");

        var response = await client.GetAsync(new Uri(sb.ToString()));
        var bytes = await response.Content.ReadAsByteArrayAsync();

        pngImage = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
        return pngImage;
    }

}
