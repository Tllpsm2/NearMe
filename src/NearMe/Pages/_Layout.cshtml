@using Microsoft.AspNetCore.Components.Web
@namespace NearMe.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content="Find nearby stores with NearMe — powered by Azure Maps">
    <base href="~/"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css"/>
    <link href="css/site.css" rel="stylesheet"/>
    <link href="NearMe.styles.css" rel="stylesheet"/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <link rel="stylesheet" href="https://atlas.microsoft.com/sdk/javascript/mapcontrol/3/atlas.min.css"/>
    <link href="_content/Syncfusion.Blazor.Themes/bootstrap5.css" rel="stylesheet"/>
    <style>
        #map {
            display: block;
            width: 100%;
            min-width: 300px;
            height: calc(100vh - 3.5rem);
            min-height: 420px;
        }
    </style>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered"/>
</head>
<body>
@RenderBody()

<script src="_content/Syncfusion.Blazor/scripts/syncfusion-blazor.min.js" defer></script>
<script src="_content/Blazor.Geolocation/blazorators.geolocation.g.js" defer></script>
<script src="https://atlas.microsoft.com/sdk/javascript/mapcontrol/3/atlas.min.js" defer></script>
<script src="_content/AzureMapsControl.Components/azure-maps-control.js" defer></script>
<script src="js/map-helpers.js" defer></script>
<script type="module">
    azureMapsControl.Extensions.getTokenCallback = (resolve, reject, map) => {
        DotNet.invokeMethodAsync('NearMe', 'GetAccessToken')
            .then(function (token) {
                resolve(token);
            });
    };
</script>
<script src="_framework/blazor.server.js"></script>
</body>
</html>
