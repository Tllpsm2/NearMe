@using Microsoft.AspNetCore.Components.Web
@namespace NearMe.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="~/"/>
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css"/>
    <link href="css/site.css" rel="stylesheet"/>
    <link href="NearMe.styles.css" rel="stylesheet"/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <link rel="stylesheet" href="https://atlas.microsoft.com/sdk/javascript/mapcontrol/3/atlas.min.css" type="text/css"/>
    <link href="_content/Syncfusion.Blazor.Themes/bootstrap5.css" rel="stylesheet"/>
    <script src="_content/Syncfusion.Blazor/scripts/syncfusion-blazor.min.js" type="text/javascript"></script>
    <style>
        #map {
            display: block;
            width: 100%;
            min-width: 300px;
            height: 70vh;
            min-height: 420px;
        }
    </style>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered"/>
</head>
<body>
@RenderBody()

<script src="_content/Blazor.Geolocation/blazorators.geolocation.g.js"></script>
<script src="https://atlas.microsoft.com/sdk/javascript/mapcontrol/3/atlas.min.js"></script>
<script src="_content/AzureMapsControl.Components/azure-maps-control.js"></script>
<script src="js/map-helpers.js"></script>
<script type="text/javascript">
    azureMapsControl.Extensions.getTokenCallback = (resolve, reject, map) => {
        DotNet.invokeMethodAsync('NearMe', 'GetAccessToken')
            .then(function (token) {
                resolve(token);
            });
    };
</script>
<script src="_framework/blazor.server.js"></script>
</body>
</html>
